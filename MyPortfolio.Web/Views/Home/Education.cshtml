@model IEnumerable<MyPortfolio.Web.Models.Entities.Education>
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

<div class="minimal-section">
@foreach (var education in Model)
{
    // Extract first 3 chars for standard abbreviation, e.g. BIR for Biruni. Or split spaces.
    var abbrevParts = education.School.Split(new[] { ' ' }, StringSplitOptions.RemoveEmptyEntries);
    string abbrev = "";
    if (abbrevParts.Length >= 2) {
        abbrev = (abbrevParts[0].Substring(0, 3) + "\n" + abbrevParts[1].Substring(0, 3)).ToUpper();
    } else {
        abbrev = education.School.Length > 3 ? education.School.Substring(0, 3).ToUpper() : education.School.ToUpper();
    }

    <div class="minimal-row">
        <div class="minimal-logo-box" style="white-space: pre-line; text-align: center; line-height: 1.2; font-size: 0.75rem; color: #6366f1;">
            @if (!string.IsNullOrEmpty(education.ImageUrl))
            {
                <img src="@education.ImageUrl" alt="Logo" style="width: 100%; height: 100%; object-fit: cover; border-radius: 8px;" />
            }
            else
            {
                @abbrev
            }
        </div>
        <div class="minimal-content">
            <div class="minimal-header">
                <div class="minimal-title">@education.School</div>
                <div class="minimal-date">@education.DateRange</div>
            </div>
            <div class="minimal-subtitle" style="margin-bottom: 0.5rem;">
                @education.Department
                <br />
                <span style="font-size: 0.9em; color:#9ca3af;">@education.Description</span>
            </div>
        </div>
    </div>
}
</div>

