@model IEnumerable<MyPortfolio.Web.Models.Entities.Experience>
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

<div class="minimal-section">
@foreach (var experience in Model)
{
    // Extract first 2 characters as an abbreviation for the logo box
    var abbrev = experience.Company.Length >= 2 ? experience.Company.Substring(0, 2).ToUpper() : experience.Company.ToUpper();

    <div class="minimal-row">
        <div class="minimal-logo-box">
            @if (!string.IsNullOrEmpty(experience.ImageUrl))
            {
                <img src="@experience.ImageUrl" alt="Logo" style="width: 100%; height: 100%; object-fit: cover; border-radius: 8px;" />
            }
            else
            {
                @abbrev
            }
        </div>
        <div class="minimal-content">
            <div class="minimal-header">
                <div class="minimal-title">@experience.Company</div>
                <div class="minimal-date">@experience.DateRange</div>
            </div>
            <div class="minimal-subtitle">
                @experience.Title
                @if (!string.IsNullOrEmpty(experience.Location))
                {
                    <text> &middot; @experience.Location</text>
                }
            </div>
            
            @if (experience.ExperienceResponsibilities != null && experience.ExperienceResponsibilities.Any())
            {
                <ul class="minimal-list">
                    @foreach(var responsibility in experience.ExperienceResponsibilities)
                    {
                        <li>@responsibility.Description</li>
                    }
                </ul>
            }
        </div>
    </div>
}
</div>
