@model MyPortfolio.Web.Models.Entities.About
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<MyPortfolio.Web.SharedResource> Localizer

@if (Model != null && !string.IsNullOrEmpty(Model.CvDocumentUrl))
{
    <a class="nav-link" href="@Model.CvDocumentUrl" download="@Model.CvOriginalFileName">
        <i class="fe fe-download"></i> @(Localizer["DownloadCV"] ?? "CV'mi İndir")
    </a>
}
else
{
    <a class="nav-link text-muted disabled" href="#" style="pointer-events: none; cursor: default;">
        <i class="fe fe-download"></i> CV Yok
    </a>
} 