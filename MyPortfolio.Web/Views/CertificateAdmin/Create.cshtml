@model MyPortfolio.Web.Models.ViewModels.CertificateViewModel

@{
    ViewData["Title"] = "Yeni Sertifika Ekle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<br />
<h4>Yeni Sertifika Ekleme Sayfası</h4>
<hr />

<form asp-action="Create" method="post" enctype="multipart/form-data">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="row">
        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="Title_tr" class="control-label"></label>
                <input asp-for="Title_tr" class="form-control" />
                <span asp-validation-for="Title_tr" class="text-danger"></span>
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="Title_en" class="control-label"></label>
                <input asp-for="Title_en" class="form-control" />
                <span asp-validation-for="Title_en" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="form-group">
                <label class="control-label">Yayıncı / Issuer</label>
                <input asp-for="Issuer_tr" class="form-control" />
                <span asp-validation-for="Issuer_tr" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="DateRange_tr" class="control-label"></label>
                <input asp-for="DateRange_tr" class="form-control" placeholder="örn: Ocak 2024" />
                <span asp-validation-for="DateRange_tr" class="text-danger"></span>
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="DateRange_en" class="control-label"></label>
                <input asp-for="DateRange_en" class="form-control" placeholder="e.g. January 2024" />
                <span asp-validation-for="DateRange_en" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="form-group">
        <label asp-for="DisplayOrder" class="control-label"></label>
        <input asp-for="DisplayOrder" class="form-control" type="number" style="max-width:120px;" />
        <span asp-validation-for="DisplayOrder" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="PdfFile" class="control-label"></label>
        <input asp-for="PdfFile" class="form-control-file" type="file" accept=".pdf" />
        <small class="text-muted">Sadece PDF dosyası kabul edilir.</small>
        <span asp-validation-for="PdfFile" class="text-danger"></span>
    </div>

    <br />
    <div class="form-group">
        <input type="submit" value="Kaydet" class="btn btn-primary" />
        <a asp-action="Index" class="btn btn-secondary">Listeye Geri Dön</a>
    </div>
</form>
