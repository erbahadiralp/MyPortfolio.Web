@model IEnumerable<MyPortfolio.Web.Models.Entities.Certificate>

@{
    ViewData["Title"] = "Sertifikalar";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<br />
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>Sertifikalar</h4>
    <a asp-action="Create" class="btn btn-primary"><i class="fe fe-plus"></i> Yeni Sertifika Ekle</a>
</div>
<hr />

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>#</th>
            <th>Başlık (TR)</th>
            <th>Başlık (EN)</th>
            <th>Yayıncı (TR)</th>
            <th>Sıralama</th>
            <th>PDF</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Title_tr</td>
                <td>@item.Title_en</td>
                <td>@item.Issuer_tr</td>
                <td>@item.DisplayOrder</td>
                <td>
                    @if (!string.IsNullOrEmpty(item.PdfUrl))
                    {
                        <a href="@Url.Content("~/static/certificates/" + item.PdfUrl)" target="_blank" class="btn btn-sm btn-outline-info">
                            <i class="fe fe-file-text"></i> Görüntüle
                        </a>
                    }
                    else
                    {
                        <span class="text-muted">—</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">
                        <i class="fe fe-edit"></i> Düzenle
                    </a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                        <i class="fe fe-trash-2"></i> Sil
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
