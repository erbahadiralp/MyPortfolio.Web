@model MyPortfolio.Web.Models.ViewModels.CertificateViewModel

@{
    ViewData["Title"] = "Sertifika Düzenle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<br />
<h4>Sertifika Düzenleme Sayfası</h4>
<hr />

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ExistingPdfUrl" />

    <div class="row">
        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="Title_tr" class="control-label"></label>
                <input asp-for="Title_tr" class="form-control" />
                <span asp-validation-for="Title_tr" class="text-danger"></span>
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="Title_en" class="control-label"></label>
                <input asp-for="Title_en" class="form-control" />
                <span asp-validation-for="Title_en" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="Issuer_tr" class="control-label"></label>
                <input asp-for="Issuer_tr" class="form-control" />
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="Issuer_en" class="control-label"></label>
                <input asp-for="Issuer_en" class="form-control" />
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="DateRange_tr" class="control-label"></label>
                <input asp-for="DateRange_tr" class="form-control" />
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="DateRange_en" class="control-label"></label>
                <input asp-for="DateRange_en" class="form-control" />
            </div>
        </div>
    </div>

    <div class="form-group">
        <label asp-for="DisplayOrder" class="control-label"></label>
        <input asp-for="DisplayOrder" class="form-control" type="number" style="max-width:120px;" />
    </div>

    <div class="form-group">
        <label asp-for="PdfFile" class="control-label"></label>
        <input asp-for="PdfFile" class="form-control-file" type="file" accept=".pdf" />
        <small class="text-muted">Sadece PDF dosyası kabul edilir. Değiştirmek istemiyorsanız boş bırakın.</small>
        @if (!string.IsNullOrEmpty(Model.ExistingPdfUrl))
        {
            <div class="mt-1">
                <small>Mevcut: <a href="@Url.Content("~/static/certificates/" + Model.ExistingPdfUrl)" target="_blank">@Model.ExistingPdfUrl</a></small>
            </div>
        }
    </div>

    <br />
    <div class="form-group">
        <input type="submit" value="Güncelle" class="btn btn-primary" />
        <a asp-action="Index" class="btn btn-secondary">Listeye Geri Dön</a>
    </div>
</form>
